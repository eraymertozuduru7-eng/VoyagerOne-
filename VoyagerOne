            </div>
        </div>

        <!-- Launch & Terminal -->
        <div>
            <h2 class="text-xl font-semibold text-white mb-4">Fırlatma Tarihi: 30 Temmuz 2026</h2>
            <div class="bg-gray-900 border border-gray-700 rounded-xl p-6 font-mono text-sm">
                <p class="text-green-400 mb-2">$ git clone https://github.com/VoyagerOne</p>
                <p class="text-gray-500">// VoyagerOne yerel AI mimarisi için hazır olun.</p>
            </div>
            
            <a href="https://github.com/VoyagerOne" class="mt-6 inline-block w-full text-center bg-white text-black font-semibold py-3 rounded-lg hover:bg-gray-200 transition">
